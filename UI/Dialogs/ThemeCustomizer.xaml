<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Personalize Theme" Width="460" Height="740" WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI Variable Display, Segoe UI, sans-serif">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{Theme_Fg}"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="{Theme_BtnBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="{Theme_BtnBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.8"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{Theme_Bg}" CornerRadius="8" BorderBrush="{Theme_BtnBorder}" BorderThickness="1" Margin="15">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.3" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TitleBar -->
            <Border x:Name="TitleBar" Grid.Row="0" Background="Transparent" Padding="20,18,20,10" Cursor="Hand">
                <StackPanel>
                    <TextBlock Text="Personalize Application" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="Customize your interface and user preferences." FontSize="12" Foreground="{Theme_SecFg}" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>

            <!-- Scrollable Settings List -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,10,20,10">
                <StackPanel>
                    
                    <TextBlock Text="Appearance" FontSize="14" FontWeight="SemiBold" Foreground="{Theme_SecFg}" Margin="0,0,0,12"/>
                    
                    <!-- Color Mode -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Color Mode:" VerticalAlignment="Center" FontSize="13"/>
                        <ComboBox x:Name="cbTheme" Grid.Column="1" Height="28">
                            <ComboBoxItem Content="Light Theme"/>
                            <ComboBoxItem Content="Dark Theme"/>
                        </ComboBox>
                    </Grid>

                    <!-- Accent Color -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Accent Color:" VerticalAlignment="Center" FontSize="13"/>
                        <ComboBox x:Name="cbAccent" Grid.Column="1" Height="28">
                            <ComboBoxItem Content="Azure Blue"/>
                            <ComboBoxItem Content="Rustic Orange"/>
                            <ComboBoxItem Content="Emerald Green"/>
                            <ComboBoxItem Content="Amethyst Purple"/>
                            <ComboBoxItem Content="Custom Hex..."/>
                        </ComboBox>
                    </Grid>
                    
                    <!-- Custom Hex Field (Toggled Visually) -->
                    <TextBox x:Name="txtCustomHex" Visibility="Collapsed" HorizontalAlignment="Right" Width="195" Height="28" Margin="0,0,0,14"/>

                    <!-- Background Image -->
                    <TextBlock Text="Background Image:" FontSize="13" Margin="0,10,0,6"/>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtAppImage" Grid.Column="0" Height="28" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                        <Button x:Name="btnBrowseApp" Grid.Column="1" Content="..." Width="30" Height="28" Background="{Theme_BtnBg}" Foreground="{Theme_Fg}" BorderBrush="{Theme_BtnBorder}" BorderThickness="1" Margin="0,0,4,0" ToolTip="Browse for background image" AutomationProperties.Name="Browse for background image"/>
                        <Button x:Name="btnClearApp" Grid.Column="2" Content="X" Width="30" Height="28" Background="{Theme_BtnBg}" Foreground="{Theme_Fg}" BorderBrush="{Theme_BtnBorder}" BorderThickness="1" ToolTip="Clear background image" AutomationProperties.Name="Clear background image"/>
                    </Grid>

                    <Separator Background="{Theme_BtnBorder}" Margin="0,10,0,20"/>

                    <TextBlock Text="Layout &amp; Sizing" FontSize="14" FontWeight="SemiBold" Foreground="{Theme_SecFg}" Margin="0,0,0,12"/>
                    
                    <!-- Density -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="List Density:" VerticalAlignment="Center" FontSize="13"/>
                        <ComboBox x:Name="cbDensity" Grid.Column="1" Height="28">
                            <ComboBoxItem Content="Comfortable (Default)"/>
                            <ComboBoxItem Content="Compact"/>
                        </ComboBox>
                    </Grid>

                    <!-- Font Size -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Global Font Size:" VerticalAlignment="Center" FontSize="13"/>
                        <ComboBox x:Name="cbFontSize" Grid.Column="1" Height="28">
                            <ComboBoxItem Content="Small"/>
                            <ComboBoxItem Content="Default"/>
                            <ComboBoxItem Content="Large"/>
                        </ComboBox>
                    </Grid>

                    <!-- Glass Effect -->
                    <CheckBox x:Name="chkGlassEffect" Content="Enable Glass Transparency Effect" FontSize="13" Margin="0,5,0,15"/>

                    <Separator Background="{Theme_BtnBorder}" Margin="0,10,0,20"/>

                    <!-- Search History -->
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Search History" FontSize="14" FontWeight="SemiBold" Foreground="{Theme_SecFg}" VerticalAlignment="Center"/>
                        <Button x:Name="btnClearHistory" Content="Clear All" Width="60" Height="22" HorizontalAlignment="Right" Background="{Theme_BtnBg}" Foreground="{Theme_Fg}" BorderBrush="{Theme_BtnBorder}" BorderThickness="1" FontSize="11"/>
                    </Grid>
                    <TextBlock Text="One item per line. Edit, remove, or sort items manually below." FontSize="11" Foreground="{Theme_SecFg}" Margin="0,0,0,8"/>
                    <TextBox x:Name="txtSearchHistory" AcceptsReturn="True" TextWrapping="NoWrap" Height="100" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"/>

                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <Border Grid.Row="2" Background="{Theme_BtnBg}" CornerRadius="0,0,8,8" Padding="16,12" BorderThickness="0,1,0,0" BorderBrush="{Theme_BtnBorder}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnSavePrefs" Content="Save Changes" Width="110" Height="28" Margin="0,0,8,0" Background="{Theme_PrimaryBg}" Foreground="{Theme_PrimaryFg}" BorderThickness="0" IsDefault="True"/>
                    <Button x:Name="btnCancelPrefs" Content="Cancel" Width="80" Height="28" Background="{Theme_BtnBg}" Foreground="{Theme_Fg}" BorderBrush="{Theme_BtnBorder}" BorderThickness="1" IsCancel="True"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>