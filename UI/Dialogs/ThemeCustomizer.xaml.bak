<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Personalize Appearance" Width="420" SizeToContent="Height" WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI Variable Display, Segoe UI, sans-serif">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.8"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Bd" Property="Opacity" Value="0.4"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{Theme_BtnBg}"/>
            <Setter Property="Foreground" Value="{Theme_Fg}"/>
            <Setter Property="BorderBrush" Value="{Theme_BtnBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{Theme_BtnBg}"/>
            <Setter Property="Foreground" Value="{Theme_Fg}"/>
            <Setter Property="BorderBrush" Value="{Theme_BtnBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{Theme_Fg}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>
    <Border Background="{Theme_Bg}" CornerRadius="8" BorderBrush="{Theme_BtnBorder}" BorderThickness="1" Margin="15">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.3" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <Border x:Name="TitleBar" Grid.Row="0" Background="Transparent" Padding="20,20,20,0" Cursor="Hand">
                <TextBlock Text="Personalize Appearance" FontSize="16" FontWeight="SemiBold" Foreground="{Theme_Fg}"/>
            </Border>

            <!-- Settings cards -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,0">
                <StackPanel Margin="20,14,20,20">

                    <!-- Theme -->
                    <Border Margin="0,0,0,8" Padding="14,10" Background="{Theme_BtnBg}" CornerRadius="6" BorderBrush="{Theme_GridBorder}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Application Theme" FontWeight="SemiBold" Foreground="{Theme_SecFg}" FontSize="13" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cbTheme" Grid.Column="1">
                                <ComboBoxItem Content="Light Mode"/>
                                <ComboBoxItem Content="Dark Mode"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- Accent Color -->
                    <Border Margin="0,0,0,8" Padding="14,10" Background="{Theme_Bg}" CornerRadius="6" BorderBrush="{Theme_GridBorder}" BorderThickness="1">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Accent Color" FontWeight="SemiBold" Foreground="{Theme_SecFg}" FontSize="13" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cbAccent" Grid.Column="1">
                                    <ComboBoxItem Content="Azure Slate (Default)"/>
                                    <ComboBoxItem Content="Rustic Editorial"/>
                                    <ComboBoxItem Content="Emerald Forest"/>
                                    <ComboBoxItem Content="Amethyst Night"/>
                                    <ComboBoxItem Content="Custom Hex Color"/>
                                </ComboBox>
                            </Grid>
                            <!-- Custom hex input — shown only when Custom is selected -->
                            <TextBox x:Name="txtCustomHex" Visibility="Collapsed" Margin="0,8,0,0"
                                     Text="#FF007F" ToolTip="Double-click to open color picker, or type a hex code"/>
                        </StackPanel>
                    </Border>

                    <!-- List Density -->
                    <Border Margin="0,0,0,8" Padding="14,10" Background="{Theme_BtnBg}" CornerRadius="6" BorderBrush="{Theme_GridBorder}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="List Density" FontWeight="SemiBold" Foreground="{Theme_SecFg}" FontSize="13" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cbDensity" Grid.Column="1">
                                <ComboBoxItem Content="Comfortable (Default)"/>
                                <ComboBoxItem Content="Compact"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- Font Size -->
                    <Border Margin="0,0,0,8" Padding="14,10" Background="{Theme_Bg}" CornerRadius="6" BorderBrush="{Theme_GridBorder}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Font Size" FontWeight="SemiBold" Foreground="{Theme_SecFg}" FontSize="13" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cbFontSize" Grid.Column="1">
                                <ComboBoxItem Content="Small"/>
                                <ComboBoxItem Content="Default"/>
                                <ComboBoxItem Content="Large"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- Background Image -->
                    <Border Margin="0,0,0,8" Padding="14,10" Background="{Theme_BtnBg}" CornerRadius="6" BorderBrush="{Theme_GridBorder}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Background Image" FontWeight="SemiBold" Foreground="{Theme_SecFg}" FontSize="13" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txtAppImage" Grid.Column="0" Height="30" Margin="0,0,6,0" ToolTip="Path to background image file"/>
                                <Button x:Name="btnBrowseApp" Grid.Column="1" Content="Browse" Width="60" Height="30" Margin="0,0,6,0" Background="{Theme_BtnBg}" Foreground="{Theme_Fg}" BorderBrush="{Theme_BtnBorder}" BorderThickness="1" ToolTip="Browse for image"/>
                                <Button x:Name="btnClearApp"  Grid.Column="2" Content="Clear"  Width="50" Height="30"                   Background="{Theme_BtnBg}" Foreground="{Theme_Fg}" BorderBrush="{Theme_BtnBorder}" BorderThickness="1" ToolTip="Remove background image"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Glass Effect -->
                    <Border Margin="0,0,0,0" Padding="14,12" Background="{Theme_Bg}" CornerRadius="6" BorderBrush="{Theme_GridBorder}" BorderThickness="1">
                        <CheckBox x:Name="chkGlassEffect" Content="Enable glass window opacity"/>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer buttons -->
            <Border Grid.Row="2" Background="{Theme_BtnBg}" CornerRadius="0,0,8,8" Padding="16,12" BorderThickness="0,1,0,0" BorderBrush="{Theme_BtnBorder}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnSavePrefs"   Content="Save Preferences" Width="130" Height="28" Margin="0,0,8,0" Background="{Theme_PrimaryBg}" Foreground="{Theme_PrimaryFg}" BorderThickness="0" IsDefault="True"/>
                    <Button x:Name="btnCancelPrefs" Content="Cancel"            Width="80"  Height="28"                   Background="{Theme_BtnBg}"    Foreground="{Theme_Fg}"      BorderBrush="{Theme_BtnBorder}" BorderThickness="1" IsCancel="True"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
