<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Pelican CU Helpdesk Companion" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource WindowBackground}"
        FontSize="{DynamicResource AppFontSize}"
        FontFamily="Segoe UI Variable Display, Segoe UI, sans-serif"
        WindowStyle="None">
    
    <Window.Resources>
        <!-- Dynamic Settings Resources -->
        <sys:Double x:Key="AppFontSize">13</sys:Double>
        <sys:Double x:Key="ListItemHeight">30</sys:Double>

        <!-- Base Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverFill}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- IconButton Style -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverFill}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Global Application Background Image Layer -->
        <Border Background="{DynamicResource WindowBackgroundImage}"/>

        <!-- Main Layout Layer -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ========================================== -->
            <!-- SIDEBAR (LEFT COLUMN)                      -->
            <!-- ========================================== -->
            <Border Grid.Column="0" Background="{DynamicResource LeftPanelBackground}" BorderBrush="{DynamicResource ControlStroke}" BorderThickness="0,0,1,0" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0">
                        <!-- Title & Subtitle -->
                        <TextBlock x:Name="lblTitle" Text="Helpdesk Companion" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock x:Name="lblSubtitle" Text="Search less. Solve more." FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,25"/>
                        
                        <!-- Main Action Buttons -->
                        <Button x:Name="btnRefresh" Content="Refresh List" Height="40" Background="{DynamicResource AccentFill}" Foreground="White" BorderThickness="0" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,15"/>
                        
                        <UniformGrid Columns="2" Rows="1" Margin="0,0,0,25">
                            <Button x:Name="btnUnlock" Content="Unlock Selected" Margin="0,0,0,0"/>
                            <Button x:Name="btnUnlockAll" Content="Unlock All" Margin="5,0,0,0"/>
                        </UniformGrid>

                        <!-- Search Area -->
                        <TextBlock Text="Search" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8"/>
                        <!-- Editable ComboBox: text field + dropdown arrow shows recent searches -->
                        <ComboBox x:Name="txtSearch" Height="32" IsEditable="True" AutomationProperties.Name="Search Users and Computers"
          Background="{DynamicResource CardBackground}"
          Foreground="{DynamicResource TextPrimary}"
          BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1"
          Margin="0,0,0,4" VerticalContentAlignment="Center"
          StaysOpenOnEdit="True"
          ToolTip="Type a name to search. Click the arrow to see recent searches.">
    <ComboBox.ItemTemplate>
        <DataTemplate>
            <Grid Width="230">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding}" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
                <!-- The 'X' button for removal -->
                <Button Grid.Column="1" Content="&#xE711;" FontFamily="Segoe MDL2 Assets" 
                        FontSize="10" Width="20" Height="20" Background="Transparent" 
                        BorderThickness="0" Foreground="{DynamicResource TextPrimary}"
                        Tag="{Binding}" x:Name="btnRemoveHistoryItem" AutomationProperties.Name="Remove from history"
                        ToolTip="Remove from history" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Opacity" Value="0.4"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="1.0"/>
                                    <Setter Property="Foreground" Value="#E81123"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </DataTemplate>
    </ComboBox.ItemTemplate>
</ComboBox>
                        <TextBlock Text="Search detects Users and Computers. Click arrow for history." FontSize="10" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <Button x:Name="btnSearch" Content="Search" Height="32" Margin="0,0,0,25"/>

                        <!-- Automation Area -->
                        <TextBlock Text="Automation" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8"/>
                        <ComboBox x:Name="cbAutoRefresh" Height="32" VerticalContentAlignment="Center" Margin="0,0,0,15" Background="{DynamicResource CardBackground}" Foreground="{DynamicResource TextPrimary}"/>
                        
                        <CheckBox x:Name="chkAutoUnlock" Content="Auto-Unlock accounts" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>
                        <CheckBox x:Name="chkEnableEmail" Content="Send email alerts" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"/>

                        <!-- Management Dashboard -->
                        <Button x:Name="btnOpenDashboard" Content="Management Dashboard" Height="34" Background="{DynamicResource CardBackground}" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1" FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Close App Button (Bottom Left) -->
                    <Button x:Name="btnBottomClose" Grid.Row="1" Content="Close Application" Height="40" Background="{DynamicResource CardBackground}" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1" FontWeight="SemiBold" FontSize="14" Margin="0,20,0,0"/>
                </Grid>
            </Border>

            <!-- ========================================== -->
            <!-- MAIN CONTENT (RIGHT COLUMN)                -->
            <!-- ========================================== -->
            <Grid Grid.Column="1" Background="{DynamicResource RightPanelBackground}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Header -->
                    <RowDefinition Height="3*"/>   <!-- ListView Area -->
                    <RowDefinition Height="Auto"/> <!-- Splitter -->
                    <RowDefinition Height="1*"/>   <!-- Log Area -->
                </Grid.RowDefinitions>

                <!-- Header Section (Now draggable) -->
                <Border x:Name="TitleBar" Grid.Row="0" Padding="20,15" BorderBrush="{DynamicResource ControlStroke}" BorderThickness="0,0,0,1" Background="Transparent">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Account List" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock x:Name="lblStatus" Text="Found 0 locked accounts. (Last Update: 00:00:00)" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="btnThemeToggle" Style="{StaticResource IconButtonStyle}" ToolTip="Toggle Theme" AutomationProperties.Name="Toggle Theme">
                                <Path x:Name="iconTheme" Fill="{DynamicResource AccentFill}" Stretch="Uniform" Width="16" Height="16" Data="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9c0-.46-.04-.92-.1-1.36-.98 1.37-2.58 2.26-4.4 2.26-3.03 0-5.5-2.47-5.5-5.5 0-1.82.89-3.42 2.26-4.4-.44-.06-.9-.1-1.36-.1z"/>
                            </Button>
                            <Button x:Name="btnDashboard" Style="{StaticResource IconButtonStyle}" ToolTip="Dashboard" AutomationProperties.Name="Dashboard">
                                <Path Fill="{DynamicResource AccentFill}" Stretch="Uniform" Width="16" Height="16" Data="M3 3h8v8H3zm10 0h8v8h-8zM3 13h8v8H3zm10 0h8v8h-8z"/>
                            </Button>
                            <Button x:Name="btnPreferences" Style="{StaticResource IconButtonStyle}" ToolTip="Personalize Theme" AutomationProperties.Name="Personalize Theme">
                                <Path Fill="{DynamicResource AccentFill}" Stretch="Uniform" Width="16" Height="16" Data="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9c.83 0 1.5-.67 1.5-1.5 0-.39-.15-.74-.39-1.01-.23-.26-.38-.61-.38-.99 0-.83.67-1.5 1.5-1.5H16c2.76 0 5-2.24 5-5 0-4.42-4.03-8-9-8zm-5.5 9c-.83 0-1.5-.67-1.5-1.5S5.67 9 6.5 9 8 9.67 8 10.5 7.33 12 6.5 12zm3-4C8.67 8 8 7.33 8 6.5S8.67 5 9.5 5s1.5.67 1.5 1.5S10.33 8 9.5 8zm5 0c-.83 0-1.5-.67-1.5-1.5S13.67 5 14.5 5s1.5.67 1.5 1.5S15.33 8 14.5 8zm3 4c-.83 0-1.5-.67-1.5-1.5S16.67 9 17.5 9s1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/>
                            </Button>
                            <Button x:Name="btnModifyConfig" Style="{StaticResource IconButtonStyle}" ToolTip="Master Configuration" AutomationProperties.Name="Master Configuration">
                                <Path Fill="{DynamicResource AccentFill}" Stretch="Uniform" Width="16" Height="16" Data="M19.4 13c0-.3.1-.6.1-.9s0-.6-.1-.9l2.1-1.7c.2-.2.2-.4.1-.6l-2-3.5c-.1-.2-.3-.3-.6-.2l-2.5 1c-.5-.4-1.1-.7-1.7-1l-.4-2.6c0-.2-.2-.4-.5-.4h-4c-.3 0-.5.2-.5.4l-.4 2.7c-.6.2-1.2-.6-1.7 1L5 4.3c-.2-.1-.5-.1-.6.1l-2 3.5c-.1.2-.1.5.1.6L4.6 10c0 .3-.1.6-.1.9s0 .6.1.9l-2.1 1.7c-.2.2-.2.4-.1.6l2 3.5c.1.2.3.3.6.2l2.5-1c.5.4 1.1.7 1.7 1l.4 2.6c0 .2.2.4.5.4h4c.3 0 .5-.2.5-.4l.4-2.7c.6-.2 1.2-.6 1.7-1l2.5 1c.2.1.5.1.6-.1l2-3.5c.1-.2.1-.5-.1-.6l-2.1-1.6zM12 15.5c-1.9 0-3.5-1.6-3.5-3.5s1.6-3.5 3.5-3.5 3.5 1.6 3.5 3.5-1.6 3.5-3.5 3.5z"/>
                            </Button>
                            <Button x:Name="btnHelp" Style="{StaticResource IconButtonStyle}" ToolTip="Help" AutomationProperties.Name="Help">
                                <Path Fill="{DynamicResource AccentFill}" Stretch="Uniform" Width="16" Height="16" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H8c0-2.21 1.79-4 4-4s4 1.79 4 4c0 .88-.36 1.68-.93 2.25z"/>
                            </Button>
                            <Button x:Name="btnTechDocs" Style="{StaticResource IconButtonStyle}" ToolTip="Documentation" AutomationProperties.Name="Documentation">
                                <Path Fill="{DynamicResource AccentFill}" Stretch="Uniform" Width="16" Height="16" Data="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z"/>
                            </Button>
                            
                            <!-- Close App Icon (Top Right) -->
                            <Button x:Name="btnTopClose" Style="{StaticResource IconButtonStyle}" ToolTip="Close Application" AutomationProperties.Name="Close Application" Margin="15,0,0,0">
                                <Path Fill="{DynamicResource AccentFill}" Stretch="Uniform" Width="14" Height="14" Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ListView Section -->
                <ListView x:Name="lvData" Grid.Row="1" Margin="10" Background="Transparent" Foreground="{DynamicResource TextPrimary}" BorderThickness="0" AlternationCount="2">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Height" Value="{DynamicResource ListItemHeight}"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            <Style.Triggers>
                                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                    <Setter Property="Background" Value="{DynamicResource AltRowBg}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentFill}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView x:Name="gvData"/>
                    </ListView.View>
                    <ListView.ContextMenu>
                        <ContextMenu>

                            <!-- COMPUTER ITEMS -->

                            <!-- Monitor + settings wrench = System Manager -->
                            <MenuItem x:Name="ctxViewProcesses" Header="Manage Computer" Visibility="Collapsed">
                                <MenuItem.Icon><Viewbox Width="16" Height="16"><Path Fill="{DynamicResource AccentFill}" Data="M21 2H3a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h7v2H8v2h8v-2h-2v-2h7a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2zm0 14H3V4h18z"/></Viewbox></MenuItem.Icon>
                            </MenuItem>

                            <!-- App Icon = Software Manager -->
                            <MenuItem x:Name="MenuItem_SoftwareManager" Header="Manage Software" Visibility="Collapsed">
                                <MenuItem.Icon>
                                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE118;" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource AccentFill}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </MenuItem.Icon>
                            </MenuItem>

                            <!-- Chip / hardware info card -->
                            <MenuItem x:Name="ctxDeviceInfo" Header="Device Info" Visibility="Collapsed">
                                <MenuItem.Icon><Viewbox Width="16" Height="16"><Path Fill="{DynamicResource AccentFill}" Data="M4 6h16v2H4zm0 5h16v2H4zm0 5h16v2H4z"/></Viewbox></MenuItem.Icon>
                            </MenuItem>

                            <!-- Printer -->
                            <MenuItem x:Name="ctxPrinterMenu" Header="Printer Management" Visibility="Collapsed">
                                <MenuItem.Icon><Viewbox Width="16" Height="16"><Path Fill="{DynamicResource AccentFill}" Data="M19 8H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zm-3 11H8v-5h8v5zm3-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm-1-9H6v4h12V3z"/></Viewbox></MenuItem.Icon>
                            </MenuItem>

                            <!-- Person with clock = active sessions -->
                            <MenuItem x:Name="ctxActiveUsers" Header="Active Sessions" Visibility="Collapsed">
                                <MenuItem.Icon><Viewbox Width="16" Height="16"><Path Fill="{DynamicResource AccentFill}" Data="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></Viewbox></MenuItem.Icon>
                            </MenuItem>

                            <!-- Shield/policy document = GPResult -->
                            <MenuItem x:Name="ctxGPResult" Header="GPResult" Visibility="Collapsed">
                                <MenuItem.Icon><Viewbox Width="16" Height="16"><Path Fill="{DynamicResource AccentFill}" Data="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 4l5 2.18V11c0 3.5-2.33 6.79-5 7.93-2.67-1.14-5-4.43-5-7.93V7.18L12 5zm-1 5v2h2v-2h-2zm0-4v3h2V6h-2z"/></Viewbox></MenuItem.Icon>
                            </MenuItem>

                            <!-- Clock = uptime -->
                            <MenuItem x:Name="ctxUptime" Header="Get Uptime" Visibility="Collapsed">
                                <MenuItem.Icon><Viewbox Width="16" Height="16"><Path Fill="{DynamicResource AccentFill}" Data="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/></Viewbox></MenuItem.Icon>
                            </MenuItem>

                            <!-- Terminal / command prompt = PowerShell -->
                            <MenuItem x:Name="ctxPSSession" Header="PowerShell Session" Visibility="Collapsed">
                                <MenuItem.Icon><Viewbox Width="16" Height="16"><Path Fill="{DynamicResource AccentFill}" Data="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 14H4V6h16v12zM6 10l1.41 1.41L9 9.83V15h2V9.83l1.59 1.59L14 10l-4-4-4 4z"/></Viewbox></MenuItem.Icon>
                            </MenuItem>

                            <!-- Lightning bolt = power options -->
                            <MenuItem x:Name="ctxPowerMenu" Header="Power Options" Visibility="Collapsed">
                                <MenuItem.Icon><Viewbox Width="16" Height="16"><Path Fill="{DynamicResource AccentFill}" Data="M7 2v11h3v9l7-12h-4l4-8z"/></Viewbox></MenuItem.Icon>
                                <MenuItem x:Name="ctxRestartComputer" Header="Restart Computer">
                                    <MenuItem.Icon><Viewbox Width="16" Height="16"><Path Fill="{DynamicResource AccentFill}" Data="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z"/></Viewbox></MenuItem.Icon>
                                </MenuItem>
                                <MenuItem x:Name="ctxShutdownComputer" Header="Shutdown Computer">
                                    <MenuItem.Icon><Viewbox Width="16" Height="16"><Path Fill="{DynamicResource AccentFill}" Data="M13 3h-2v10h2V3zm4.83 2.17l-1.42 1.42C17.99 7.86 19 9.81 19 12c0 3.87-3.13 7-7 7s-7-3.13-7-7c0-2.19 1.01-4.14 2.58-5.42L6.17 5.17C4.23 6.82 3 9.26 3 12c0 4.97 4.03 9 9 9s9-4.03 9-9c0-2.74-1.23-5.18-3.17-6.83z"/></Viewbox></MenuItem.Icon>
                                </MenuItem>
                            </MenuItem>

                            <Separator x:Name="ctxSep1" Visibility="Collapsed"/>

                            <!-- USER ITEMS -->

                            <!-- Open padlock = unlock -->
                            <MenuItem x:Name="ctxUnlock" Header="Unlock Account" Visibility="Collapsed">
                                <MenuItem.Icon><Viewbox Width="16" Height="16"><Path Fill="{DynamicResource AccentFill}" Data="M12 17c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm6-9h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6h1.9c0-1.71 1.39-3.1 3.1-3.1s3.1 1.39 3.1 3.1v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2z"/></Viewbox></MenuItem.Icon>
                            </MenuItem>

                            <!-- Key = reset password -->
                            <MenuItem x:Name="ctxReset" Header="Reset Password" Visibility="Collapsed">
                                <MenuItem.Icon><Viewbox Width="16" Height="16"><Path Fill="{DynamicResource AccentFill}" Data="M12.65 10C11.83 7.67 9.61 6 7 6c-3.31 0-6 2.69-6 6s2.69 6 6 6c2.61 0 4.83-1.67 5.65-4H17v4h4v-4h2v-4H12.65zM7 14c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z"/></Viewbox></MenuItem.Icon>
                            </MenuItem>

                            <!-- Info card = view details -->
                            <MenuItem x:Name="ctxDetails" Header="View Details" Visibility="Collapsed">
                                <MenuItem.Icon><Viewbox Width="16" Height="16"><Path Fill="{DynamicResource AccentFill}" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></Viewbox></MenuItem.Icon>
                            </MenuItem>

                            <!-- Magnifying glass with lock = lockout source -->
                            <MenuItem x:Name="ctxLockoutSource" Header="Find Lockout Source" Visibility="Collapsed">
                                <MenuItem.Icon><Viewbox Width="16" Height="16"><Path Fill="{DynamicResource AccentFill}" Data="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></Viewbox></MenuItem.Icon>
                            </MenuItem>

                            <!-- People/groups = group membership -->
                            <MenuItem x:Name="ctxGroups" Header="Group Membership" Visibility="Collapsed">
                                <MenuItem.Icon><Viewbox Width="16" Height="16"><Path Fill="{DynamicResource AccentFill}" Data="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></Viewbox></MenuItem.Icon>
                            </MenuItem>

                            <Separator x:Name="ctxSep2" Visibility="Collapsed"/>

                            <!-- FRESHSERVICE ITEMS -->

                            <!-- Add/plus ticket = log quick ticket -->
                            <MenuItem x:Name="ctxQuickTicket" Header="Log Quick Ticket" Visibility="Collapsed">
                                <MenuItem.Icon><Viewbox Width="16" Height="16"><Path Fill="{DynamicResource AccentFill}" Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-2 10h-4v4h-2v-4H7v-2h4V7h2v4h4v2z"/></Viewbox></MenuItem.Icon>
                            </MenuItem>

                            <!-- Stack of tickets / list = recent tickets -->
                            <MenuItem x:Name="ctxTicketFeed" Header="Recent Tickets" Visibility="Collapsed">
                                <MenuItem.Icon><Viewbox Width="16" Height="16"><Path Fill="{DynamicResource AccentFill}" Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/></Viewbox></MenuItem.Icon>
                            </MenuItem>

                            <!-- Monitor with search = find user's computer -->
                            <MenuItem x:Name="ctxFindComputer" Header="Find User's Computer" Visibility="Collapsed">
                                <MenuItem.Icon><Viewbox Width="16" Height="16"><Path Fill="{DynamicResource AccentFill}" Data="M20 18c1.1 0 1.99-.9 1.99-2L22 6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2H0v2h24v-2h-4zM4 6h16v10H4V6zm8 7c-1.03 0-1.94-.52-2.48-1.3L8 13l.03-4 1.5 1.5c.54-.77 1.44-1.28 2.47-1.28 1.66 0 3 1.34 3 3s-1.34 3-3 3z"/></Viewbox></MenuItem.Icon>
                            </MenuItem>

                            <!-- External link / person card = open FS record -->
                            <MenuItem x:Name="ctxOpenFSRecord" Header="Open Freshservice Record" Visibility="Collapsed">
                                <MenuItem.Icon><Viewbox Width="16" Height="16"><Path Fill="{DynamicResource AccentFill}" Data="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></Viewbox></MenuItem.Icon>
                            </MenuItem>

                            <!-- Device/asset tag = FS inventory -->
                            <MenuItem x:Name="ctxFSInventory" Header="Freshservice Asset" Visibility="Collapsed">
                                <MenuItem.Icon><Viewbox Width="16" Height="16"><Path Fill="{DynamicResource AccentFill}" Data="M20 6h-2.18c.07-.44.18-.86.18-1.3C18 2.57 15.43 0 12.3 0c-1.85 0-3.47.93-4.47 2.35L7 3.5l-.83-1.15C5.17.93 3.55 0 1.7 0 .76 0 0 .76 0 1.7v.09C0 4.03 1.57 6 4 6H2c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-8.3 12H7v-2h4.7v2zm4 0h-2v-2h2v2zm0-4H7v-2h8.7v2z"/></Viewbox></MenuItem.Icon>
                            </MenuItem>

                        </ContextMenu>
                    </ListView.ContextMenu>
                </ListView>

                <!-- Splitter for Resizing Log Area -->
                <GridSplitter Grid.Row="2" Height="6" HorizontalAlignment="Stretch" Background="Transparent" Cursor="SizeNS"/>

                <!-- Log Section -->
                <Border Grid.Row="3" Background="{DynamicResource LeftPanelBackground}" BorderBrush="{DynamicResource ControlStroke}" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Grid Grid.Row="0" Margin="15,10,15,5">
                            <TextBlock Text="Event Log" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            <Button x:Name="btnViewLog" Content="View Logs" HorizontalAlignment="Right" Padding="10,4" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1" Foreground="{DynamicResource TextPrimary}"/>
                        </Grid>
                        
                        <Border Grid.Row="1" Margin="15,0,15,15" Background="{DynamicResource RightPanelBackground}" BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1" CornerRadius="4">
                            <RichTextBox x:Name="txtLog" Padding="8" Background="Transparent" BorderThickness="0" IsReadOnly="True" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12">
                                <FlowDocument>
                                    <Paragraph Margin="0" Foreground="{DynamicResource TextSecondary}">Application Loaded. Waiting for events...</Paragraph>
                                </FlowDocument>
                            </RichTextBox>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ========================================== -->
        <!-- OVERLAYS (Z-Index Top)                     -->
        <!-- ========================================== -->
        
        <!-- Reset Password Overlay -->
        <Grid x:Name="overlayReset" Grid.ColumnSpan="2" Background="#99000000" Visibility="Collapsed">
            <Border Background="{DynamicResource CardBackground}" CornerRadius="8" BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="25" Width="450">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Opacity="0.4" ShadowDepth="5"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock x:Name="txtPwdTitle" Text="Reset Password" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="Target User:" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtResetUsername" IsReadOnly="True" Background="{DynamicResource LeftPanelBackground}" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource ControlStroke}" Margin="0,0,0,15" Padding="6"/>
                    
                    <TextBlock Text="New Password:" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,15">
                        <PasswordBox x:Name="txtResetPassword" Padding="6" Foreground="{DynamicResource TextPrimary}" Background="{DynamicResource LeftPanelBackground}" BorderBrush="{DynamicResource ControlStroke}"/>
                        <TextBox x:Name="txtResetPasswordVisible" Padding="6" Visibility="Collapsed" Foreground="{DynamicResource TextPrimary}" Background="{DynamicResource LeftPanelBackground}" BorderBrush="{DynamicResource ControlStroke}"/>
                    </Grid>

                    <TextBlock Text="Confirm Password:" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,15">
                        <PasswordBox x:Name="txtConfirmPassword" Padding="6" Foreground="{DynamicResource TextPrimary}" Background="{DynamicResource LeftPanelBackground}" BorderBrush="{DynamicResource ControlStroke}"/>
                        <TextBox x:Name="txtConfirmPasswordVisible" Padding="6" Visibility="Collapsed" Foreground="{DynamicResource TextPrimary}" Background="{DynamicResource LeftPanelBackground}" BorderBrush="{DynamicResource ControlStroke}"/>
                    </Grid>
                    
                    <CheckBox x:Name="chkShowPassword" Content="Show Passwords" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                    <CheckBox x:Name="chkMustChange" Content="User must change password at next logon" Foreground="{DynamicResource TextPrimary}" IsChecked="True" Margin="0,0,0,15"/>
                    
                    <TextBlock x:Name="lblMatchStatus" Foreground="{DynamicResource Danger}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,15"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnGeneratePass" Content="Generate Strong" Margin="0,0,10,0" Background="{DynamicResource LeftPanelBackground}"/>
                        <Button x:Name="btnConfirmReset" Content="Reset Password" Margin="0,0,10,0" Background="{DynamicResource AccentFill}" Foreground="White" BorderThickness="0"/>
                        <Button x:Name="btnCancelReset" Content="Cancel" Background="{DynamicResource LeftPanelBackground}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Detailed Information Side Panel -->
        <!-- Appears as a third column in the right content grid when a row is selected.  -->
        <!-- Visibility toggled by ShowDetailsAction / btnCloseDetails in UI_Core.psm1.  -->
        <Grid x:Name="overlayDetails" Grid.ColumnSpan="2" Background="#88000000" Visibility="Collapsed">
            <Border x:Name="borderDetails"
                    Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1,0,0,0"
                    HorizontalAlignment="Right" VerticalAlignment="Stretch"
                    Width="380" MinHeight="300">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="-4" Direction="180" Opacity="0.35"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Panel header with visible close button -->
                    <Border Grid.Row="0" Background="{DynamicResource LeftPanelBackground}"
                            Padding="16,12,12,12" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource ControlStroke}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock x:Name="lblDetailsPanelTitle" Text="Account Details"
                                           FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock x:Name="lblDetailsPanelSub" Text=""
                                           FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <!-- Close button - always visible, clearly labeled -->
                            <Button x:Name="btnCloseDetails" Grid.Column="1"
                                    Content=">"
                                    Padding="12,0" Height="30" ToolTip="Close Details Panel" AutomationProperties.Name="Close Details Panel"
                                    Background="{DynamicResource ControlStroke}"
                                    Foreground="{DynamicResource TextPrimary}"
                                    BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1"
                                    FontSize="16" FontWeight="Bold"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Scrollable card rows -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="pnlDetailsCards" Margin="12,10,12,10">

                            <!-- Key fields as named cards - populated by ShowDetailsAction -->
                            <Border x:Name="cardDet_DisplayName" Margin="0,0,0,5" Padding="12,8"
                                    Background="{DynamicResource RightPanelBackground}" CornerRadius="5"
                                    BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Display Name" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtDet_DisplayName" Grid.Column="1" Text=""
                                               Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>

                            <Border Margin="0,0,0,5" Padding="12,8"
                                    Background="{DynamicResource LeftPanelBackground}" CornerRadius="5"
                                    BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="SAM Account" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtDet_SAM" Grid.Column="1" Text=""
                                               Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>

                            <Border Margin="0,0,0,5" Padding="12,8"
                                    Background="{DynamicResource RightPanelBackground}" CornerRadius="5"
                                    BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Employee ID" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtDet_EmployeeID" Grid.Column="1" Text=""
                                               Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>

                            <Border Margin="0,0,0,5" Padding="12,8"
                                    Background="{DynamicResource LeftPanelBackground}" CornerRadius="5"
                                    BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Employee Number" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtDet_EmployeeNumber" Grid.Column="1" Text=""
                                               Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>

                            <Border Margin="0,0,0,5" Padding="12,8"
                                    Background="{DynamicResource RightPanelBackground}" CornerRadius="5"
                                    BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Email" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtDet_Email" Grid.Column="1" Text=""
                                               Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>

                            <Border Margin="0,0,0,5" Padding="12,8"
                                    Background="{DynamicResource LeftPanelBackground}" CornerRadius="5"
                                    BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Department" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtDet_Department" Grid.Column="1" Text=""
                                               Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>

                            <Border Margin="0,0,0,5" Padding="12,8"
                                    Background="{DynamicResource RightPanelBackground}" CornerRadius="5"
                                    BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Title" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtDet_Title" Grid.Column="1" Text=""
                                               Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>

                            <Border Margin="0,0,0,5" Padding="12,8"
                                    Background="{DynamicResource LeftPanelBackground}" CornerRadius="5"
                                    BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Manager" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtDet_Manager" Grid.Column="1" Text=""
                                               Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>

                            <Border Margin="0,0,0,5" Padding="12,8"
                                    Background="{DynamicResource RightPanelBackground}" CornerRadius="5"
                                    BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Phone" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtDet_Phone" Grid.Column="1" Text=""
                                               Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>

                            <Border Margin="0,0,0,5" Padding="12,8"
                                    Background="{DynamicResource LeftPanelBackground}" CornerRadius="5"
                                    BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Account Status" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtDet_AccountStatus" Grid.Column="1" Text=""
                                               FontSize="12" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Border Margin="0,0,0,5" Padding="12,8"
                                    Background="{DynamicResource RightPanelBackground}" CornerRadius="5"
                                    BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Last Logon" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtDet_LastLogon" Grid.Column="1" Text=""
                                               Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Border Margin="0,0,0,5" Padding="12,8"
                                    Background="{DynamicResource LeftPanelBackground}" CornerRadius="5"
                                    BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Pwd Last Set" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtDet_PwdLastSet" Grid.Column="1" Text=""
                                               Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Border Margin="0,0,0,5" Padding="12,8"
                                    Background="{DynamicResource RightPanelBackground}" CornerRadius="5"
                                    BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Pwd Expires" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtDet_PwdExpiry" Grid.Column="1" Text=""
                                               FontSize="12" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Border Margin="0,0,0,5" Padding="12,8"
                                    Background="{DynamicResource LeftPanelBackground}" CornerRadius="5"
                                    BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Account Expiry" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtDet_AccountExpiry" Grid.Column="1" Text=""
                                               Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Border Margin="0,0,0,5" Padding="12,8"
                                    Background="{DynamicResource RightPanelBackground}" CornerRadius="5"
                                    BorderBrush="{DynamicResource ControlStroke}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="OU / Path" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondary}" FontSize="12" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                    <TextBlock x:Name="txtDet_OU" Grid.Column="1" Text=""
                                               Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </Border>

                            <!-- Raw dump (full AD properties) inside an Expander -->
                            <Expander Header="All AD Properties" Foreground="{DynamicResource TextSecondary}"
                                      FontSize="12" Margin="0,8,0,0" IsExpanded="False">
                                <TextBox x:Name="txtDetailsContent" IsReadOnly="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" Background="Transparent"
                                         Foreground="{DynamicResource TextPrimary}" BorderThickness="0"
                                         FontFamily="Consolas" FontSize="11" Margin="0,6,0,0"/>
                            </Expander>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Footer: close button + resize handle -->
                    <Border Grid.Row="2" Padding="12,10" Background="{DynamicResource LeftPanelBackground}"
                            BorderThickness="0,1,0,0" BorderBrush="{DynamicResource ControlStroke}">
                        <Grid>
                            <Thumb x:Name="thumbResizeDetails" HorizontalAlignment="Right" VerticalAlignment="Top"
                                   Width="10" Height="10" Cursor="SizeWE" Background="Transparent"
                                   ToolTip="Drag left edge to resize panel" Margin="0,-2,-2,0"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>